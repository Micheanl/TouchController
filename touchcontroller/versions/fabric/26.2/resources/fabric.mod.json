{
    "schemaVersion": 1,
    "id": "touchcontroller-26-2-fabric",
    "version": "${version}",
    "name": "TouchController",
    "description": "${description}",
    "authors": "mod_authors_array",
    "contributors": "mod_contributors_array",
    "contact": {
        "homepage": "${home_page}",
        "sources": "${sources_page}",
        "issues": "${issue_tracker}"
    },
    "license": "${license}",
    "icon": "assets/touchcontroller/textures/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "top.fifthlight.touchcontroller.fabric.v26_2.TouchController"
        ],
        "modmenu": [
            "top.fifthlight.touchcontroller.fabric.v26_2.TouchControllerModMenuApiImpl"
        ]
    },
    "mixins": [
        {
            "config": "touchcontroller.mixins.fabric.json",
            "environment": "client"
        }
    ],
    "depends": {
        "minecraft": [
            "26.2"
        ],
        "java": ">=25",
        "combine": "^${combine_version}",
        "fabric-api": "*",
        "fabric-language-kotlin": "*",
        "touchcontroller-26-2": "=${version}"
    }
}
