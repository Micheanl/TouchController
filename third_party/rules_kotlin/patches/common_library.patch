+++ b/kotlin/internal/jvm/kt_common.bzl
@@ -0,0 +1,88 @@
+"""kt_common_library rule for Kotlin Multiplatform common source fragments."""
+
+load(
+    "//kotlin/internal:defs.bzl",
+    _KtCommonInfo = "KtCommonInfo",
+)
+
+def _kt_common_library_impl(ctx):
+    fragment_name = ctx.attr.fragment_name if ctx.attr.fragment_name else ctx.label.name
+
+    refines = []
+    transitive_refines = []
+    transitive_srcs = []
+
+    for dep in ctx.attr.deps:
+        if _KtCommonInfo in dep:
+            info = dep[_KtCommonInfo]
+            refines.append(info)
+            transitive_refines.append(info.transitive_refines)
+            transitive_srcs.append(info.transitive_srcs)
+
+    srcs = ctx.files.srcs
+
+    return [
+        _KtCommonInfo(
+            fragment_name = fragment_name,
+            srcs = srcs,
+            refines = refines,
+            transitive_refines = depset(
+                direct = refines,
+                transitive = transitive_refines,
+            ),
+            transitive_srcs = depset(
+                direct = srcs,
+                transitive = transitive_srcs,
+            ),
+        ),
+        DefaultInfo(files = depset(srcs)),
+    ]
+
+kt_common_library = rule(
+    doc = """\
+    Defines a Kotlin Multiplatform common source fragment.
+
+    A kt_common_library provides KtCommonInfo, which carries the fragment name,
+    source files, and refines (dependency) relationships.
+
+    Example:
+
+    ```bzl
+    kt_common_library(
+        name = "common",
+        srcs = glob(["src/commonMain/kotlin/**/*.kt"]),
+        fragment_name = "commonMain",
+    )
+
+    kt_common_library(
+        name = "mid",
+        srcs = glob(["src/midMain/kotlin/**/*.kt"]),
+        fragment_name = "midMain",
+        deps = [":common"],  # midMain refines commonMain
+    )
+
+    kt_jvm_library(
+        name = "lib",
+        srcs = glob(["src/jvmMain/kotlin/**/*.kt"]),
+        deps = [":mid"],  # jvmMain refines midMain
+    )
+    ```
+    """,
+    attrs = {
+        "srcs": attr.label_list(
+            doc = "Kotlin source files belonging to this fragment.",
+            allow_files = [".kt"],
+            default = [],
+        ),
+        "deps": attr.label_list(
+            doc = "Other kt_common_library targets that this fragment refines.",
+            default = [],
+            providers = [_KtCommonInfo],
+        ),
+        "fragment_name": attr.string(
+            doc = "Name of this fragment (e.g. 'commonMain'). If not provided, generate from target name.",
+        ),
+    },
+    implementation = _kt_common_library_impl,
+    provides = [_KtCommonInfo],
+)

