load("@rules_java//java:java_import.bzl", "java_import")

package(default_visibility = ["//visibility:public"])

java_import(
    name = "sdk",
    jars = glob(["lib/*.jar"]),
    srcjar = "@intellij_sources//jar",
)

java_import(
    name = "java",
    jars = glob([
        "plugins/java/lib/*.jar",
        "plugins/java/lib/modules/*.jar",
    ]) + ["plugins/java/lib/resources/jdkAnnotations.jar"],
)

java_import(
    name = "kotlin",
    jars = glob(["plugins/Kotlin/lib/*.jar"]),
)
