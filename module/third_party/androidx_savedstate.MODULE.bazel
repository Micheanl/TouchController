"MODULE.bazel androidx.savedstate source build"

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_archive(
    name = "androidx_savedstate",
    build_file = "@//third_party/androidx_savedstate:BUILD.savedstate_desktop.bazel",
