load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library", "cc_shared_library")
load("@rules_java//java:defs.bzl", "java_library")

cc_binary(
    name = "generator",
    srcs = ["src/main/c/generate_enums.c"],
    linkopts = [
        "-framework",
        "CoreFoundation",
        "-framework",
        "Security",
    ],
    target_compatible_with = ["@platforms//os:macos"],
)

genrule(
    name = "generate_enums",
    outs = [
        "OSXKeychainAuthenticationType.java",
        "OSXKeychainProtocolType.java",
    ],
    cmd = "$(location :generator) $(location OSXKeychainAuthenticationType.java) $(location OSXKeychainProtocolType.java)",
    target_compatible_with = ["@platforms//os:macos"],
    tools = [":generator"],
)

cc_library(
    name = "osxkeychain",
    srcs = [
        "src/main/c/pt_davidafsilva_apple_OSXKeychain.c",
        "src/main/c/pt_davidafsilva_apple_OSXKeychain.h",
    ],
    copts = [
        "-std=c99",
        "-pedantic",
        "-Wall",
    ],
    linkopts = [
        "-framework",
        "CoreFoundation",
        "-framework",
        "Security",
    ],
    target_compatible_with = ["@platforms//os:macos"],
    deps = ["@rules_jni//jni"],
)

cc_shared_library(
    name = "osxkeychain_shared",
    shared_lib_name = "osxkeychain.dylib",
    target_compatible_with = ["@platforms//os:macos"],
    deps = [":osxkeychain"],
)

java_library(
    name = "jkeychain",
    srcs = [
        "src/main/java/pt/davidafsilva/apple/OSXKeychain.java",
        "src/main/java/pt/davidafsilva/apple/OSXKeychainException.java",
        ":generate_enums",
    ],
    resources = [":osxkeychain_shared"],
    target_compatible_with = ["@platforms//os:macos"],
    visibility = ["//visibility:public"],
)
