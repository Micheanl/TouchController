{
    "schemaVersion": 1,
    "id": "${mod_id}-vanilla",
    "version": "${version}",
    "name": "${name-vanilla}",
    "description": "${description-vanilla}",
    "authors": ["fifth_light"],
    "license": "${license}",
    "icon": "icon.png",
    "contact": {
        "homepage": "${home_page}",
        "sources": "${sources_page}",
        "issues": "${issue_tracker}"
    },
    "environment": "client",
    "depends": {
        "minecraft": ">=1.21.2"
    },
    "custom": {
        "modmenu": {
            "parent": "${mod_id}",
            "badges": ["library"]
        }
    }
}
